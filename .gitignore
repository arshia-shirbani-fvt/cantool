# Ignore everything by default

*

# Allow folders so git can traverse them

!*/

# === Keep specific project files ===

!parseCANEdge.py
!requirements.txt
!README.md
!.gitignore

# === Keep all Python source files ===

!*.py

# === Keep these empty folders ===

!dbc/
!decoded/
!raw/
!merged/

# Keep placeholder files inside them

!dbc/.gitkeep
!decoded/.gitkeep
!raw/.gitkeep
!merged/.gitkeep

# But still ignore contents of those folders

dbc/*
decoded/*
raw/*
merged/*

# Re-allow placeholder files after folder contents ignored

!dbc/.gitkeep
!decoded/.gitkeep
!raw/.gitkeep
!merged/.gitkeep
